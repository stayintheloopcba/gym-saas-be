# =============================================================================
# generic-saas-be — Variables de entorno
# =============================================================================
# Copia este archivo como .env:
#   cp .env.example .env
# Los defaults asumen que el Postgres de docker-compose está corriendo:
#   docker compose up -d
# Nunca versionar el .env real (solo este .env.example).
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
# URL canonica del frontend (Vite), usada para redirecciones como Google OAuth.
FRONTEND_URL=http://localhost:5173
# Lista explicita de origins permitidos por CORS. Util para puertos alternativos
# de Vite; separar multiples origins con coma.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# -----------------------------------------------------------------------------
# PostgreSQL / TypeORM
# -----------------------------------------------------------------------------
# Estas mismas variables alimentan el docker-compose (Postgres) y la app (TypeORM).
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=generic_saas
# synchronize: true SOLO en desarrollo. En producción usar migraciones (false).
DB_SYNCHRONIZE=true
DB_SSL=false

# -----------------------------------------------------------------------------
# JWT / Auth — cookies httpOnly (access + refresh)
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Cookies que transportan los tokens (no exponer tokens al JS del frontend).
COOKIE_DOMAIN=localhost
# true solo detrás de HTTPS (producción). En local dejar en false.
COOKIE_SECURE=false
# Rondas de salt para bcrypt.
BCRYPT_SALT_ROUNDS=10

# -----------------------------------------------------------------------------
# Organizaciones / multi-tenant
# -----------------------------------------------------------------------------
# Cookie httpOnly que transporta la organización activa del request. Su valor
# nunca se confía solo: el middleware lo valida contra las membresías del usuario.
ACTIVE_ORG_COOKIE=active_org
# Tiempo de vida de una invitación (formato de la librería `ms`, p. ej. 7d, 48h).
INVITATION_TTL=7d
# Emails (separados por coma) que el seeder marca como platform admin (SUPER_ADMIN) al bootstrap.
PLATFORM_ADMIN_EMAILS=

# -----------------------------------------------------------------------------
# Google OAuth (/auth/google, /auth/google/callback)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# -----------------------------------------------------------------------------
# MinIO / almacenamiento de archivos (S3-compatible)
# -----------------------------------------------------------------------------
# Estas variables alimentan el docker-compose (servicio minio) y la app (adapter).
# Consola web: http://localhost:9001 (login con ACCESS_KEY / SECRET_KEY).
# Un único bucket multi-tenant; las keys llevan prefijo por org/usuario
# (org/<id>/logo, users/<id>/avatar).
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=admin
# Mínimo 8 caracteres (MinIO rechaza el arranque con una más corta).
MINIO_SECRET_KEY=adminadmin
MINIO_BUCKET=generic-saas
MINIO_USE_SSL=false
# URL pública de lectura de los objetos (en dev, la API S3 directa).
MINIO_PUBLIC_URL=http://localhost:9000/generic-saas
